{
    "name": "jadwalisasi",
    "private": true,
    "type": "module",
    "imports": {
        "#/*": "./src/*"
    },
    "scripts": {
        "dev": "vite dev --port 3000",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "format": "biome format",
        "lint": "biome lint",
        "check": "biome check",
        "post-cta-init": "bunx --bun create-db@latest --user-agent tanstack/tsrouter",
        "db:generate": "dotenv -e .env.local -- prisma generate",
        "db:push": "dotenv -e .env.local -- prisma db push",
        "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
        "db:studio": "dotenv -e .env.local -- prisma studio",
        "db:reset": "dotenv -e .env.local -- prisma migrate reset",
        "db:seed": "dotenv -e .env.local -- prisma db seed",
        "db:fresh": "bun run db:reset && bun run db:migrate --name init && bun run db:generate && bun run db:seed"
    },
    "dependencies": {
        "@heroicons/react": "^2.2.0",
        "@internationalized/date": "^3.12.0",
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "@react-aria/i18n": "^3.12.16",
        "@tailwindcss/vite": "^4.1.18",
        "@tanstack/react-devtools": "latest",
        "@tanstack/react-form": "latest",
        "@tanstack/react-router": "latest",
        "@tanstack/react-router-devtools": "latest",
        "@tanstack/react-router-ssr-query": "latest",
        "@tanstack/react-start": "latest",
        "@tanstack/router-plugin": "^1.132.0",
        "better-auth": "^1.5.3",
        "clsx": "^2.1.1",
        "dayjs": "^1.11.20",
        "motion": "^12.38.0",
        "nitro": "^3.0.260311-beta",
        "prisma": "^7.4.2",
        "react": "^19.2.0",
        "react-aria-components": "^1.16.0",
        "react-dom": "^19.2.0",
        "sonner": "^2.0.7",
        "srvx": "^0.11.15",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.1.18",
        "tailwindcss-react-aria-components": "^2.0.1",
        "tw-animate-css": "^1.4.0",
        "use-debounce": "^10.1.0",
        "xlsx": "^0.18.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.5",
        "@tailwindcss/typography": "^0.5.16",
        "@tanstack/devtools-vite": "latest",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.0",
        "@types/node": "^22.10.2",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^5.1.4",
        "babel-plugin-react-compiler": "^1.0.0",
        "dotenv-cli": "^11.0.0",
        "jsdom": "^28.1.0",
        "tsx": "^4.21.0",
        "typescript": "^5.7.2",
        "vite": "^7.3.1",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.0.5"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "lightningcss"
        ]
    }
}
